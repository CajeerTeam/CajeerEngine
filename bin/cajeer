#!/usr/bin/env php
<?php

declare(strict_types=1);

use Cajeer\Compatibility\Dle\DleAdapter;
use Cajeer\Compatibility\WordPress\Scanner\PluginScanner;
use Cajeer\Config\ConfigRepository;
use Cajeer\Database\DatabaseManager;
use Cajeer\Database\MigrationRunner;
use Cajeer\Modules\Auth\Security\PasswordHasher;

$basePath = dirname(__DIR__);
require_once $basePath . '/core/bootstrap.php';

$command = $argv[1] ?? 'help';

function out(string $message): void { fwrite(STDOUT, $message . PHP_EOL); }

try {
    match ($command) {
        'health' => health($basePath),
        'install' => install($basePath, $argv),
        'cache:clear' => cache_clear($basePath),
        'migrate' => migrate($basePath, $argv),
        'migrate:status' => migrate_status($basePath, $argv),
        'dle:scan-template' => dle_scan_template($basePath, $argv),
        'wp:scan-plugin' => wp_scan_plugin($basePath, $argv),
        default => help(),
    };
} catch (Throwable $e) {
    fwrite(STDERR, 'Ошибка: ' . $e->getMessage() . PHP_EOL);
    exit(1);
}

function help(): void
{
    out('Cajeer Engine CLI');
    out('Команды:');
    out('  php bin/cajeer install --admin-email=admin@example.test --admin-password=secret');
    out('  php bin/cajeer health');
    out('  php bin/cajeer migrate --database=mysql');
    out('  php bin/cajeer migrate:status --database=pgsql');
    out('  php bin/cajeer cache:clear');
    out('  php bin/cajeer dle:scan-template themes/default/main.tpl');
    out('  php bin/cajeer wp:scan-plugin plugins/example/plugin.php');
}

function opt(array $argv, string $name, mixed $default = null): mixed
{
    foreach ($argv as $arg) {
        if (str_starts_with($arg, '--' . $name . '=')) return substr($arg, strlen('--' . $name . '='));
    }
    return $default;
}

function config(string $basePath): ConfigRepository { return ConfigRepository::load(is_dir($basePath . '/configs') ? $basePath . '/configs' : $basePath . '/config'); }
function database_name(array $argv): string { return (string) opt($argv, 'database', getenv('DB_DEFAULT') ?: 'mysql'); }

function health(string $basePath): void
{
    out('status: ok');
    out('base_path: ' . $basePath);
    out('php: ' . PHP_VERSION);
    out('storage_writable: ' . (is_writable($basePath . '/storage') ? 'yes' : 'no'));
    out('installed: ' . (is_file($basePath . '/storage/installed.lock') ? 'yes' : 'no'));
}

function install(string $basePath, array $argv): void
{
    $database = database_name($argv);
    $config = config($basePath);
    $db = new DatabaseManager($config);
    $pdo = $db->connection($database);
    $count = (new MigrationRunner($pdo, $basePath . '/database/migrations'))->run($database);
    $email = (string) opt($argv, 'admin-email', 'admin@example.test');
    $username = (string) opt($argv, 'admin-username', 'admin');
    $password = (string) opt($argv, 'admin-password', 'admin123456');
    $stmt = $pdo->prepare('INSERT INTO cajeer_users (email, username, password_hash, display_name, status) VALUES (:email, :username, :password_hash, :display_name, :status)');
    try { $stmt->execute(['email' => $email, 'username' => $username, 'password_hash' => (new PasswordHasher())->make($password), 'display_name' => $username, 'status' => 'active']); } catch (Throwable) {}
    file_put_contents($basePath . '/storage/installed.lock', date(DATE_ATOM));
    out('Установка завершена. Миграций выполнено: ' . $count);
}

function cache_clear(string $basePath): void
{
    $dirs = [$basePath . '/storage/cache', $basePath . '/storage/compiled_tpl'];
    foreach ($dirs as $dir) {
        if (!is_dir($dir)) continue;
        foreach (glob($dir . '/*') ?: [] as $file) is_file($file) && unlink($file);
    }
    out('Кеш очищен.');
}

function migrate(string $basePath, array $argv): void
{
    $database = database_name($argv);
    $runner = new MigrationRunner((new DatabaseManager(config($basePath)))->connection($database), $basePath . '/database/migrations');
    $count = $runner->run($database, in_array('--dry-run', $argv, true));
    out("Выполнено миграций: {$count}");
}

function migrate_status(string $basePath, array $argv): void
{
    $database = database_name($argv);
    $runner = new MigrationRunner((new DatabaseManager(config($basePath)))->connection($database), $basePath . '/database/migrations');
    out(json_encode($runner->status($database), JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT));
}

function dle_scan_template(string $basePath, array $argv): void
{
    $file = $argv[2] ?? '';
    $path = str_starts_with($file, '/') ? $file : $basePath . '/' . $file;
    $report = (new DleAdapter())->scanTemplate($path);
    out(json_encode(['file' => $file] + $report, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT));
}

function wp_scan_plugin(string $basePath, array $argv): void
{
    $file = $argv[2] ?? '';
    $path = str_starts_with($file, '/') ? $file : $basePath . '/' . $file;
    $report = (new PluginScanner())->scan($path);
    out(json_encode($report, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT));
}
