APP_NAME="Cajeer Engine"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080
APP_KEY=change-me

DB_DEFAULT=mysql

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=cajeer
MYSQL_USERNAME=cajeer
MYSQL_PASSWORD=secret
MYSQL_CHARSET=utf8mb4

PGSQL_HOST=127.0.0.1
PGSQL_PORT=5432
PGSQL_DATABASE=cajeer
PGSQL_USERNAME=cajeer
PGSQL_PASSWORD=secret
PGSQL_CHARSET=utf8

CACHE_DRIVER=file
SESSION_DRIVER=file
LOG_CHANNEL=file

COMPAT_DLE_ENABLED=true
COMPAT_WORDPRESS_ENABLED=true
MARKETPLACE_ENABLED=true

ADMIN_EMAIL=admin@example.test
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
