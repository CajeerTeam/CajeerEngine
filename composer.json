{
  "name": "cajeer/engine",
  "description": "Cajeer Engine — PHP CMS platform with DLE and WordPress compatibility layers.",
  "type": "project",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "TheSkiF4er"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-json": "*",
    "ext-pdo": "*"
  },
  "autoload": {
    "psr-4": {
      "Cajeer\\Engine\\": "src/"
    },
    "files": [
      "src/Compatibility/WordPress/functions.php"
    ]
  },
  "bin": [
    "bin/cajeer"
  ],
  "scripts": {
    "serve": "php -S 127.0.0.1:8080 -t public public/index.php",
    "cajeer": "php bin/cajeer"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
